# Application Configuration
APP_URL=https://autoprosguests-qa.lovable.app

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# Test User Credentials (populate after creating test users)
TEST_ADMIN_EMAIL=admin@example.com
TEST_ADMIN_PASSWORD=your-admin-password

TEST_MANAGER_EMAIL=manager@example.com
TEST_MANAGER_PASSWORD=your-manager-password

TEST_DRIVER_EMAIL=driver@example.com
TEST_DRIVER_PASSWORD=your-driver-password
TEST_DRIVER_PHONE=555-0100

TEST_DISPATCHER_EMAIL=dispatcher@example.com
TEST_DISPATCHER_PASSWORD=your-dispatcher-password

TEST_PM_EMAIL=pm@example.com
TEST_PM_PASSWORD=your-pm-password

# Zapier / Webhook Configuration
ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/your-catch-id/
ZAPIER_DUAL_WRITE_MODE=true

# Test Webhook for capturing Zapier payloads (use webhook.site or local server)
TEST_WEBHOOK_URL=https://webhook.site/your-unique-id

# Optional: Local dev server config
# LOCAL_SERVER_URL=http://localhost:3000
# LOCAL_SERVER_PORT=3000

# Test Data
TEST_PROPERTY_ID=your-test-property-id
TEST_PERMIT_PLATE=TEST123
TEST_PERMIT_ID=your-test-permit-id

# Email Configuration (for testing email endpoints)
MAILGUN_API_KEY=your-mailgun-key-here
MAILGUN_DOMAIN=your-domain.mailgun.org

# Performance / Latency Testing
PERF_TIMEOUT_MS=500
PERF_P95_THRESHOLD=500

# Optional: Debug / Logging
DEBUG=false
LOG_LEVEL=info
